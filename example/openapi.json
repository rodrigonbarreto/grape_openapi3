{
  "openapi": "3.0.0",
  "info": {
    "title": "Products API",
    "version": "v1",
    "description": "A simple CRUD API for products, built with Grape."
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Development"
    }
  ],
  "tags": [
    {
      "name": "products",
      "description": "Product management"
    },
    {
      "name": "reports",
      "description": "Reporting endpoints"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List all products",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "Page number (default: 1)"
            },
            "description": "Page number (default: 1)"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "Items per page (default: 20)"
            },
            "description": "Items per page (default: 20)"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Search by name or description"
            },
            "description": "Search by name or description"
          },
          {
            "name": "category_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "Filter by category"
            },
            "description": "Filter by category"
          },
          {
            "name": "active",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Filter by active status"
            },
            "description": "Filter by active status"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListEntity"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createProduct",
        "summary": "Create a product",
        "tags": [
          "products"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Product name"
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "description": "Price in USD"
                  },
                  "stock": {
                    "type": "integer",
                    "description": "Initial stock quantity"
                  },
                  "description": {
                    "type": "string",
                    "description": "Product description",
                    "nullable": true
                  },
                  "category_id": {
                    "type": "integer",
                    "description": "Category ID (belongs_to category)",
                    "nullable": true
                  },
                  "supplier_id": {
                    "type": "integer",
                    "description": "Supplier ID (belongs_to supplier)",
                    "nullable": true
                  },
                  "active": {
                    "type": "boolean",
                    "description": "Active status (default: true)",
                    "nullable": true
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Tag list",
                    "nullable": true
                  },
                  "dimensions": {
                    "type": "object",
                    "properties": {
                      "width": {
                        "type": "number",
                        "format": "float",
                        "description": "Width in cm"
                      },
                      "height": {
                        "type": "number",
                        "format": "float",
                        "description": "Height in cm"
                      },
                      "depth": {
                        "type": "number",
                        "format": "float",
                        "description": "Depth in cm",
                        "nullable": true
                      }
                    },
                    "required": [
                      "width",
                      "height"
                    ],
                    "description": "Physical dimensions"
                  },
                  "variants": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "sku": {
                          "type": "string",
                          "description": "Variant SKU"
                        },
                        "color": {
                          "type": "string",
                          "description": "Color",
                          "nullable": true
                        },
                        "stock": {
                          "type": "integer",
                          "description": "Variant stock",
                          "nullable": true
                        }
                      },
                      "required": [
                        "sku"
                      ]
                    },
                    "description": "Product variants",
                    "nullable": true
                  }
                },
                "required": [
                  "name",
                  "price",
                  "stock",
                  "dimensions"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductEntity"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "operationId": "getProduct",
        "summary": "Get a product",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductEntity"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          }
        }
      },
      "put": {
        "operationId": "updateProduct",
        "summary": "Update a product",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Product name",
                    "nullable": true
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "description": "Price in USD",
                    "nullable": true
                  },
                  "stock": {
                    "type": "integer",
                    "description": "Stock quantity",
                    "nullable": true
                  },
                  "description": {
                    "type": "string",
                    "description": "Product description",
                    "nullable": true
                  },
                  "active": {
                    "type": "boolean",
                    "description": "Active status",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductEntity"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "delete": {
        "operationId": "deleteProduct",
        "summary": "Delete a product",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Success"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },
    "/products/{id}/image": {
      "post": {
        "operationId": "createProductImage",
        "summary": "Upload product image",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Product image (JPG/PNG, max 5MB)"
                  }
                },
                "required": [
                  "image"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageEntity"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          },
          "422": {
            "description": "Invalid file"
          }
        }
      }
    },
    "/reports/categories": {
      "get": {
        "operationId": "listReportCategories",
        "summary": "Category sales report",
        "tags": [
          "reports"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reports_CategoryEntity"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductListEntity": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductEntity"
            },
            "description": "Products"
          },
          "total": {
            "type": "integer",
            "description": "Total count"
          },
          "page": {
            "type": "integer",
            "description": "Current page"
          }
        },
        "required": [
          "data",
          "total",
          "page"
        ]
      },
      "ProductEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 42,
            "description": "Product ID"
          },
          "name": {
            "type": "string",
            "example": "Wireless Mouse",
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "example": 29.9,
            "description": "Price in USD"
          },
          "stock": {
            "type": "integer",
            "minimum": 0,
            "description": "Units in stock"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published",
              "archived"
            ],
            "default": "draft",
            "description": "Product status"
          },
          "sku": {
            "type": "string",
            "format": "uuid",
            "description": "Stock keeping unit"
          },
          "active": {
            "type": "boolean",
            "description": "Whether it is active"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tag list"
          },
          "category": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Entities_CategoryEntity"
              }
            ],
            "description": "Product category",
            "nullable": true
          },
          "supplier": {
            "allOf": [
              {
                "$ref": "#/components/schemas/SupplierEntity"
              }
            ],
            "description": "Product supplier",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "price",
          "stock",
          "status",
          "sku",
          "active"
        ]
      },
      "Entities_CategoryEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Category ID"
          },
          "name": {
            "type": "string",
            "description": "Category name"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "SupplierEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Supplier ID"
          },
          "name": {
            "type": "string",
            "description": "Supplier name"
          },
          "email": {
            "type": "string",
            "description": "Contact email",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "MessageEntity": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Response message"
          }
        },
        "required": [
          "message"
        ]
      },
      "Reports_CategoryEntity": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Category name"
          },
          "product_count": {
            "type": "integer",
            "description": "Products in category"
          },
          "revenue": {
            "type": "number",
            "format": "float",
            "description": "Total revenue"
          }
        },
        "required": [
          "name",
          "product_count",
          "revenue"
        ]
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Pass your JWT token in the Authorization header."
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ]
}
